{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "engines": {
        "node": "20"
    },
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "start": "concurrently \"php artisan serve\" \"npm run dev\" \"php artisan queue:work\" \"php artisan reverb:start\" --names=Serveur,Vite,Queues,Reverb -c bgBlue.bold,bgGreen.bold,bgMagenta.bold,bgCyan.bold --kill-others"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "tailwindcss": "^4.0.0",
        "vite": "^7.0.7"
    },
    "dependencies": {
        "laravel-echo": "^2.3.4",
        "pusher-js": "^8.5.0"
    }
}
